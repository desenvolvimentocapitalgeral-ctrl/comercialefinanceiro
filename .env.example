# Banco de dados (Neon) — pooled (PgBouncer), usado pela aplicação em runtime
DATABASE_URL="postgresql://user:password@host-pooler/dbname?sslmode=require"
# Conexão direta (sem pooler) — usada apenas por `prisma migrate`
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth / Auth.js
AUTH_SECRET="gerar-com-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# IA de interpretação de contratos (Anthropic)
ANTHROPIC_API_KEY="sk-ant-..."

# Storage de arquivos (contratos, comprovantes, recibos)
BLOB_READ_WRITE_TOKEN="vercel-blob-token"

# E-mail transacional (notificações — Prompt 4)
RESEND_API_KEY="re_..."
